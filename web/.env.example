# Local Docker MySQL: from repo root run `docker compose up -d`, then use the URL below.
DATABASE_URL="mysql://root:devpassword@localhost:3306/coursemanagement"
# Minimum ~32+ characters (256 bits) for HS256 in ASP.NET IdentityModel tokens.
JWT_KEY="super-secret-jwt-key-for-course-management-api"
JWT_ISSUER="CourseManagementAPI"
JWT_AUDIENCE="CourseManagementClient"
# Remote ASP.NET API (optional): when set, admin CRUD + login hit this origin with Bearer JWT.
# Must match appsettings.json Jwt:Key / Jwt:Issuer / Jwt:Audience with web JWT_* env.
NEXT_PUBLIC_DOTNET_API_URL=http://localhost:5007
